CONTRACT_ID=          # deployed dca-vault-contract ID on testnet
NETWORK_PASSPHRASE=   # Test SDF Network ; September 2015
RPC_URL=              # https://soroban-testnet.stellar.org
EXECUTOR_SECRET=      # secret key of the account that will call execute_swap
POLL_INTERVAL_MS=     # how often the executor polls for due schedules (e.g. 30000)
PORT=                 # express server port (e.g. 3001)
DB_PATH=              # path to sqlite db file (e.g. ./data/dca.db)
ALLOWED_ORIGIN=      # the frontend's origin, e.g. https://dca-vault-frontend.vercel.app
